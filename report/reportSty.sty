% reportSty.sty — style file for di3p project report
% Mirrors the IIITD BTP template structure

\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{microtype}

% Page geometry
\usepackage[
  top=1in, bottom=1in,
  left=1.25in, right=1in
]{geometry}

% Line spacing
\usepackage{setspace}

% Math
\usepackage{amsmath}
\usepackage{amssymb}

% Graphics
\usepackage{graphicx}
\usepackage{float}
\usepackage{tabularx}
\usepackage{booktabs}

% Tables
\usepackage{booktabs}
\usepackage{array}

% Hyperlinks (load last among most packages)
\usepackage[
  colorlinks=true,
  linkcolor=black,
  citecolor=black,
  urlcolor=blue
]{hyperref}

% Header / footer
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\leftmark}
\fancyhead[R]{\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
}